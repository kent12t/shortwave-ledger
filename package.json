{
  "name": "shortwave-ledger",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pages:build": "opennextjs-cloudflare build",
    "pages:preview": "wrangler pages dev .open-next --compatibility-flag=nodejs_compat",
    "pages:deploy": "bun run pages:build && wrangler pages deploy .open-next"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "fast-xml-parser": "^5.4.2",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "styled-jsx": "^5.1.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.71.0"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
